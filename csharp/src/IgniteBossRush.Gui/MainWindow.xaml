<Window x:Class="IgniteBossRush.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IgniteBossRush.Gui.ViewModels"
        xmlns:conv="clr-namespace:IgniteBossRush.Gui.Converters"
        Title="Ignite Rush — Seeded Competition Tool"
        Height="680" Width="1020"
        MinHeight="540" MinWidth="800"
        Style="{StaticResource IgniteWindowStyle}"
        WindowStartupLocation="CenterScreen"
        Icon="Ignite.png">

  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>

  <Window.Resources>
    <conv:StageStateToBrushConverter        x:Key="StateToBrush"/>
    <conv:StageStateToGlyphConverter        x:Key="StateToGlyph"/>
    <conv:TimeSpanToCompactStringConverter  x:Key="TimeSpanFmt"/>
    <conv:BoolToVisibilityConverter         x:Key="BoolToVis"/>
    <conv:StringNotEmptyToVisibilityConverter x:Key="StringToVis"/>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>   <!-- Header -->
      <RowDefinition Height="*"/>      <!-- Main content -->
      <RowDefinition Height="Auto"/>   <!-- Status bar -->
    </Grid.RowDefinitions>

    <!-- ================================================================
         HEADER
         ================================================================ -->
    <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
            Padding="20,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <Image Source="Ignite.png" Width="40" Height="40" Margin="0,0,12,0"
                 VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Style="{StaticResource HeadlineText}" Text="Ignite Rush"/>
            <TextBlock Style="{StaticResource SubheadText}" Margin="0,3,0,0"
                       Text="Seeded competition bundle generator for Elden Ring Boss Rush"/>
          </StackPanel>
        </StackPanel>

        <!-- Elapsed timer -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal"
                    Visibility="{Binding TotalElapsedText, Converter={StaticResource StringToVis}}">
          <TextBlock Text="&#x23F1; " FontSize="14" VerticalAlignment="Center"
                     Foreground="{StaticResource TextMutedBrush}"/>
          <TextBlock Text="{Binding TotalElapsedText}" FontFamily="Consolas" FontSize="14"
                     Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ================================================================
         MAIN CONTENT: Left steps | Center form+log | Right results
         ================================================================ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="210"/>  <!-- Step indicator -->
        <ColumnDefinition Width="*"/>    <!-- Form + log -->
        <ColumnDefinition Width="270"/>  <!-- Results panel -->
      </Grid.ColumnDefinitions>

      <!-- ==============================================================
           LEFT: Pipeline Step Indicator
           ============================================================== -->
      <Border Grid.Column="0"
              Background="{StaticResource BgDarkestBrush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="0,0,1,0"
              Padding="16,20">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="PIPELINE STAGES" FontSize="10"
                     FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"
                     Margin="0,0,0,16"/>

          <ItemsControl ItemsSource="{Binding Stages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,6" ToolTip="{Binding Description}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                  </Grid.RowDefinitions>

                  <!-- State glyph -->
                  <TextBlock Grid.Column="0"
                             Text="{Binding State, Converter={StaticResource StateToGlyph}}"
                             Foreground="{Binding State, Converter={StaticResource StateToBrush}, ConverterParameter=circle}"
                             FontSize="14" FontWeight="Bold"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>

                  <!-- Stage name -->
                  <TextBlock Grid.Column="1"
                             Text="{Binding Name}"
                             Foreground="{Binding State, Converter={StaticResource StateToBrush}, ConverterParameter=text}"
                             FontSize="12" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"/>

                  <!-- Elapsed time -->
                  <TextBlock Grid.Column="2"
                             Text="{Binding Elapsed, Converter={StaticResource TimeSpanFmt}}"
                             Foreground="{StaticResource TextMutedBrush}"
                             FontFamily="Consolas" FontSize="10"
                             VerticalAlignment="Center" Margin="4,0,0,0"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>

      <!-- ==============================================================
           CENTER: Seed/Config + Log
           ============================================================== -->
      <Grid Grid.Column="1" Margin="20,16,20,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>  <!-- Data error banner -->
          <RowDefinition Height="Auto"/>  <!-- Config card -->
          <RowDefinition Height="Auto"/>  <!-- Log header -->
          <RowDefinition Height="*"/>     <!-- Log content -->
        </Grid.RowDefinitions>

        <!-- Data folder error banner (only visible when data is missing) -->
        <Border Grid.Row="0" CornerRadius="4" Padding="12,10" Margin="0,0,0,12"
                Background="#33F44336" BorderBrush="#55F44336" BorderThickness="1"
                Visibility="{Binding DataNotReady, Converter={StaticResource BoolToVis}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="&#x26A0; Data folder incomplete" FontWeight="SemiBold"
                         FontSize="12" Foreground="{StaticResource WarningBrush}"/>
              <TextBlock Text="{Binding DataError}" FontSize="11"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh" Style="{StaticResource IconButton}"
                    Command="{Binding RefreshDataCommand}" VerticalAlignment="Center"
                    Margin="10,0,0,0"
                    ToolTip="Re-check the data folder"/>
          </Grid>
        </Border>

        <!-- Config Card: Seed + options + Generate button -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="CONFIGURATION" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource GoldPrimaryBrush}" Margin="0,0,0,14"/>

            <!-- Seed row -->
            <TextBlock Style="{StaticResource FieldLabel}" Text="Seed (hex)" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,14">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" Style="{StaticResource MonoTextBox}"
                       Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="128-bit hex seed for deterministic generation. Leave empty to auto-mint."/>
              <Button Grid.Column="1" Content="&#x2728; Mint" Style="{StaticResource IconButton}"
                      Command="{Binding MintSeedCommand}" Margin="6,0,0,0"
                      ToolTip="Generate a random 128-bit seed"/>
            </Grid>

            <!-- Zero boss drops toggle -->
            <CheckBox IsChecked="{Binding ZeroBossDrops}" Margin="0,0,0,16"
                      Content="Zero boss-drop loot (no ENEMY FELLED drop toast)"
                      ToolTip="Zeros 38 boss ItemLotParam_enemy rows and strips dispatch calls from common_func.emevd.dcx"/>

            <!-- Generate button + status -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         FontSize="12" VerticalAlignment="Center"/>

              <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                      Command="{Binding RunCommand}" IsDefault="True"
                      ToolTip="Generate the seeded competition bundle">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#x25B6; " FontSize="11" VerticalAlignment="Center"
                             Visibility="{Binding IsNotRunning, Converter={StaticResource BoolToVis}}"/>
                  <TextBlock Text="Generate Bundle"
                             Visibility="{Binding IsNotRunning, Converter={StaticResource BoolToVis}}"/>
                  <TextBlock Text="Generating..."
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Log (collapsed by default) -->
        <Expander Grid.Row="2" Grid.RowSpan="2" IsExpanded="False"
                  Foreground="{StaticResource TextMutedBrush}">
          <Expander.Header>
            <TextBlock Text="PIPELINE LOG" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}"/>
          </Expander.Header>
          <Border Background="{StaticResource BgDarkestBrush}"
                  BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                  CornerRadius="4" Height="200" Margin="0,6,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
              <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                       BorderThickness="0" Background="Transparent"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="Consolas" FontSize="11"
                       TextWrapping="NoWrap" Padding="10,8"
                       CaretBrush="Transparent"
                       TextChanged="LogTextBox_TextChanged"/>
            </ScrollViewer>
          </Border>
        </Expander>
      </Grid>

      <!-- ==============================================================
           RIGHT: Progress + Results + Actions
           ============================================================== -->
      <Border Grid.Column="2"
              Background="{StaticResource BgSurfaceBrush}"
              BorderBrush="{StaticResource BorderSubtleBrush}"
              BorderThickness="1,0,0,0"
              Padding="16,20">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>

            <!-- Progress overview -->
            <TextBlock Text="PROGRESS" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

            <TextBlock FontFamily="Consolas" FontSize="12" Margin="0,0,0,4"
                       Foreground="{StaticResource GoldPrimaryBrush}">
              <Run Text="{Binding CurrentStageIndex, Mode=OneWay}"/><Run Text=" / 7 stages"/>
            </TextBlock>

            <TextBlock Text="{Binding StatusText}" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,20"/>

            <!-- Divider -->
            <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,16"/>

            <!-- Post-run actions (visible after success) -->
            <StackPanel Visibility="{Binding PipelineSucceeded, Converter={StaticResource BoolToVis}}">

              <TextBlock Text="ACTIONS" FontSize="10" FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>

              <Button Style="{StaticResource PrimaryButton}"
                      Command="{Binding PackageZipCommand}"
                      HorizontalAlignment="Stretch" Margin="0,0,0,8"
                      Padding="12,10">
                <TextBlock Text="&#x2B73; Package Zip" FontSize="13"/>
              </Button>

              <Button Style="{StaticResource SecondaryButton}"
                      Command="{Binding OpenOutputFolderCommand}"
                      HorizontalAlignment="Stretch" Margin="0,0,0,8"
                      Padding="12,8">
                <TextBlock Text="&#x2192; Open Output Folder"/>
              </Button>

              <Button Style="{StaticResource SecondaryButton}"
                      Command="{Binding CopyAllFingerprintsCommand}"
                      HorizontalAlignment="Stretch" Margin="0,0,0,12"
                      Padding="12,8">
                <TextBlock Text="&#x2630; Copy All Fingerprints"/>
              </Button>

              <!-- Verification (collapsed by default) -->
              <Expander IsExpanded="False" Foreground="{StaticResource TextMutedBrush}">
                <Expander.Header>
                  <TextBlock Text="VERIFICATION" FontSize="10" FontWeight="SemiBold"
                             Foreground="{StaticResource TextMutedBrush}"/>
                </Expander.Header>
                <StackPanel Margin="0,8,0,0">

                  <!-- bundle_root -->
                  <Border Background="{StaticResource GoldSubtleBrush}"
                          BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="1"
                          CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="bundle_root" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource GoldPrimaryBrush}"/>
                        <Button Grid.Column="1" Content="Copy" Style="{StaticResource IconButton}"
                                Command="{Binding CopyBundleRootCommand}" Padding="6,2"
                                FontSize="10"/>
                      </Grid>
                      <TextBlock Text="{Binding BundleRoot}" FontFamily="Consolas" FontSize="10"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>

                  <!-- tier_rewards -->
                  <Border Background="{StaticResource BgElevatedBrush}"
                          CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                    <StackPanel>
                      <TextBlock Text="tier_rewards" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <TextBlock Text="{Binding TierRewardsFingerprint}" FontFamily="Consolas"
                                 FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                 TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                  </Border>

                  <!-- artifact_tree -->
                  <Border Background="{StaticResource BgElevatedBrush}"
                          CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                    <StackPanel>
                      <TextBlock Text="artifact_tree" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <TextBlock Text="{Binding ArtifactTree}" FontFamily="Consolas"
                                 FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                 TextWrapping="Wrap" Margin="0,3,0,0"/>
                    </StackPanel>
                  </Border>

                  <!-- regulation summary -->
                  <Border Background="{StaticResource BgElevatedBrush}"
                          CornerRadius="4" Padding="10,8">
                    <StackPanel>
                      <TextBlock Text="regulation rows" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                      <TextBlock Text="{Binding RegulationSummary}" FontFamily="Consolas"
                                 FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"
                                 Margin="0,3,0,0"/>
                    </StackPanel>
                  </Border>

                </StackPanel>
              </Expander>
            </StackPanel>

            <!-- Before run placeholder -->
            <TextBlock Visibility="{Binding PipelineSucceeded, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                       Text="Generate a bundle to see results here."
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap" FontStyle="Italic"/>
          </StackPanel>
        </ScrollViewer>
      </Border>

    </Grid>

    <!-- ================================================================
         STATUS BAR
         ================================================================ -->
    <Border Grid.Row="2" Background="{StaticResource BgDarkestBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
            Padding="16,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Status indicator dot -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
          <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="{StaticResource TextMutedBrush}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource GoldPrimaryBrush}"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding PipelineSucceeded}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>
          <TextBlock Text="{Binding StatusText}" FontSize="11"
                     Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Seed display -->
        <TextBlock Grid.Column="1" FontSize="11" VerticalAlignment="Center"
                   Foreground="{StaticResource TextMutedBrush}"
                   Visibility="{Binding Seed, Converter={StaticResource StringToVis}}">
          <Run Text="Seed: "/><Run Text="{Binding Seed, Mode=OneWay}" FontFamily="Consolas"/>
        </TextBlock>

        <!-- Branding -->
        <TextBlock Grid.Column="3" Text="Ignite Rush Alpha" FontSize="10"
                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                   FontStyle="Italic"/>
      </Grid>
    </Border>
  </Grid>
</Window>
