<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ================================================================
       Ignite Rush — Purple/Royal dark palette
       ================================================================ -->

  <!-- Background layers (darkest to lightest) -->
  <Color x:Key="BackgroundDarkest">#FF08060E</Color>
  <Color x:Key="BackgroundPrimary">#FF0F0B18</Color>
  <Color x:Key="BackgroundSurface">#FF181224</Color>
  <Color x:Key="BackgroundElevated">#FF1F182E</Color>
  <Color x:Key="BackgroundHover">#FF2A2240</Color>

  <!-- Purple accent tones -->
  <Color x:Key="AccentPrimary">#FF9B6DFF</Color>
  <Color x:Key="AccentLight">#FFB794FF</Color>
  <Color x:Key="AccentDark">#FF6B3FC7</Color>
  <Color x:Key="AccentMuted">#FF3D2A6B</Color>
  <Color x:Key="AccentSubtle">#339B6DFF</Color>

  <!-- Gold secondary (for highlights, fingerprints) -->
  <Color x:Key="GoldAccent">#FFD4AF37</Color>
  <Color x:Key="GoldMuted">#FF8B7500</Color>

  <!-- Text -->
  <Color x:Key="TextPrimary">#FFE8E4F0</Color>
  <Color x:Key="TextSecondary">#FFA8A0B8</Color>
  <Color x:Key="TextMuted">#FF6B6280</Color>
  <Color x:Key="TextOnAccent">#FF0F0B18</Color>

  <!-- Borders -->
  <Color x:Key="BorderDefault">#FF2D2644</Color>
  <Color x:Key="BorderSubtle">#FF211B34</Color>
  <Color x:Key="BorderFocused">#FF9B6DFF</Color>

  <!-- Status colors -->
  <Color x:Key="StatusSuccess">#FF66BB6A</Color>
  <Color x:Key="StatusWarning">#FFFFA726</Color>
  <Color x:Key="StatusError">#FFEF5350</Color>
  <Color x:Key="StatusInfo">#FF42A5F5</Color>

  <!-- ================================================================
       Brush resources
       ================================================================ -->

  <!-- Backgrounds -->
  <SolidColorBrush x:Key="BgDarkestBrush"   Color="{StaticResource BackgroundDarkest}"/>
  <SolidColorBrush x:Key="BgPrimaryBrush"   Color="{StaticResource BackgroundPrimary}"/>
  <SolidColorBrush x:Key="BgSurfaceBrush"   Color="{StaticResource BackgroundSurface}"/>
  <SolidColorBrush x:Key="BgElevatedBrush"  Color="{StaticResource BackgroundElevated}"/>
  <SolidColorBrush x:Key="BgHoverBrush"     Color="{StaticResource BackgroundHover}"/>

  <!-- Accents -->
  <SolidColorBrush x:Key="GoldPrimaryBrush" Color="{StaticResource AccentPrimary}"/>
  <SolidColorBrush x:Key="GoldLightBrush"   Color="{StaticResource AccentLight}"/>
  <SolidColorBrush x:Key="GoldDarkBrush"    Color="{StaticResource AccentDark}"/>
  <SolidColorBrush x:Key="GoldMutedBrush"   Color="{StaticResource AccentMuted}"/>
  <SolidColorBrush x:Key="GoldSubtleBrush"  Color="{StaticResource AccentSubtle}"/>

  <!-- Gold secondary -->
  <SolidColorBrush x:Key="GoldAccentBrush"  Color="{StaticResource GoldAccent}"/>

  <!-- Text -->
  <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimary}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
  <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMuted}"/>
  <SolidColorBrush x:Key="TextOnGoldBrush"    Color="{StaticResource TextOnAccent}"/>

  <!-- Borders -->
  <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}"/>
  <SolidColorBrush x:Key="BorderSubtleBrush"  Color="{StaticResource BorderSubtle}"/>
  <SolidColorBrush x:Key="BorderFocusedBrush" Color="{StaticResource BorderFocused}"/>

  <!-- Status -->
  <SolidColorBrush x:Key="SuccessBrush"  Color="{StaticResource StatusSuccess}"/>
  <SolidColorBrush x:Key="WarningBrush"  Color="{StaticResource StatusWarning}"/>
  <SolidColorBrush x:Key="ErrorBrush"    Color="{StaticResource StatusError}"/>
  <SolidColorBrush x:Key="InfoBrush"     Color="{StaticResource StatusInfo}"/>

  <!-- Gradients -->
  <LinearGradientBrush x:Key="GoldGradientBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{StaticResource AccentDark}" Offset="0"/>
    <GradientStop Color="{StaticResource AccentPrimary}" Offset="0.5"/>
    <GradientStop Color="{StaticResource AccentLight}" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF181224" Offset="0"/>
    <GradientStop Color="#FF0F0B18" Offset="1"/>
  </LinearGradientBrush>

</ResourceDictionary>
